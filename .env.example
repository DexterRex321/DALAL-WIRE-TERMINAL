# ============================================================
# DALAL WIRE — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── API SECURITY ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is a shared secret between your frontend and backend
API_SECRET=your_generated_secret_here

# Comma-separated list of allowed origins (no trailing slash)
# Example: https://dalal-wire.onrender.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── DATA PROVIDERS ───────────────────────────────────────────
# Yahoo Finance — no key required (free, used via yahoo-finance2 npm package)
# MFAPI — no key required (free, public API at api.mfapi.in)
# NSE — no key required (scraped via session cookie)
# RSS feeds — no key required

# Newsdata.io (optional — for enhanced news feed)
# Get free key at: https://newsdata.io/register
# Leave blank to use RSS-only mode
NEWSDATA_KEY=

# ── DHAN BROKER API ──────────────────────────────────────────
# Get your API credentials from: https://dhanhq.co/docs/v2/
# Step 1: Login to Dhan → My Profile → API & App
# Step 2: Create a new app, select "Read" permissions only for v1
# Step 3: Copy Client ID and Access Token below

# Your Dhan Client ID (numeric, e.g. 1234567890)
DHAN_CLIENT_ID=

# Dhan Access Token (JWT, expires every 30 days — regenerate from dashboard)
DHAN_ACCESS_TOKEN=

# Dhan API base URL (do not change unless Dhan updates their API)
DHAN_API_BASE=https://api.dhan.co

# Feature flag — set to true ONLY after you have added real credentials above
# Keeps the broker integration disabled until you are ready
FEATURE_DHAN_API=false

# ── FEATURE FLAGS ────────────────────────────────────────────
# Set to true to enable live advice signals (requires broker data)
FEATURE_ADVICE_LIVE=false

# Set to true to enable portfolio heatmap overlay
FEATURE_PORTFOLIO_OVERLAY=false

# ── DEPLOYMENT (auto-set by Render — do not set manually) ────
# RENDER_EXTERNAL_URL=https://dalal-wire.onrender.com
