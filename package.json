{
  "name": "dalal-wire",
  "version": "2.0.0",
  "description": "Bloomberg-style Indian stock market terminal — Express backend + vanilla JS frontend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
