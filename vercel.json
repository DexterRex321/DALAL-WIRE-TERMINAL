{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "server.js": {
      "maxDuration": 60,
      "includeFiles": "{dalal-worldmonitor-bridge.html,bridge-app.js,bridge-styles.css,switcher-widget.html,dalal-wire-node/public/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ]
}
